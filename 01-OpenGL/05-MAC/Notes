1) Change shader version : 410
2) Shader/Texture Error Check : 
    [self release];
    [self uninitialize];
    [NSApp terminate:self];
3) Texture Code for macOS : 
    -(GLuint)loadTexture:(const char*)textureFileName
    {
        //code
        NSBundle *appBundle = [NSBundle mainBundle];
        NSString *appDirPath = [appBundle bundlePath];
        NSString *parentDirPath = [appDirPath stringByDeletingLastPathComponent];
        //Get full path of texture file
        NSString *textureFileNameWithPath = [NSString stringWithFormat:@"%@/%s", parentDirPath, textureFileName];

        //Create image from texture file
        NSImage *image = [[NSImage alloc]initWithContentsOfFile:textureFileNameWithPath];
        if (image == nil)
        {
            fprintf(gpFile, "Failed to load texture image. \n");
            return (0);
        }

        //Convert NSImage to CGImageRef
        CGImageRef cgImage = [image CGImageForProposedRect:nil context:nil hints:nil];
        size_t width = CGImageGetWidth(cgImage);
        size_t height = CGImageGetHeight(cgImage);

        //Get image data
        CGDataProviderRef dataProvider = CGImageGetDataProvider(cgImage);
        CFDataRef cfData = CGDataProviderCopyData(dataProvider);
        void* imageData = (void*)CFDataGetBytePtr(cfData);

        GLuint texture;
        glGenTextures(1, &texture);
        glBindTexture(GL_TEXTURE_2D, texture);

        glPixelStorei(GL_UNPACK_ALIGNMENT, 1);

        glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_LINEAR);
        glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_LINEAR_MIPMAP_LINEAR);
        glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_REPEAT);
        glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_REPEAT);

        glTexImage2D(GL_TEXTURE_2D, 0, GL_RGBA, (GLsizei)width, (GLsizei)height, 0, GL_RGBA, GL_UNSIGNED_BYTE, imageData);
        glGenerateMipmap(GL_TEXTURE_2D);

        glBindTexture(GL_TEXTURE_2D, 0);

        //Release image related resources
        CFRelease(cfData);

        return (texture);
    }
4) Call to loadTexture
    Global variable : GLuint texturePyramid;
    In initialize : texturePyramid = [self loadTexture:"Stone.bmp"];
5) Tesselation Shader Title Bar Change in macOS(in display) : 
    //Prepare Title
