{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/EHsc",
                "/nologo",
                "gdi32.lib",
                "user32.lib",
                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "label": "Clean Debug Files",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "del /q /f /s *.exe *.obj *.pdb *.ilk Log.txt *.res D3DLog.txt"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Clean .gradle Folders",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "Get-ChildItem -Path . -Recurse -Directory -Filter .gradle | ForEach-Object { Remove-Item -Recurse -Force -LiteralPath $_.FullName }"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Clean All",
            "dependsOn": [
                "Clean Debug Files",
                "Clean .gradle Folders"
            ],
            "dependsOrder": "sequence"
        }
    ],
    "version": "2.0.0"
}